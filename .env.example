# Shared
DATABASE_URL=postgresql://dossier:dossier@localhost:5432/dossier
REDIS_URL=redis://localhost:6379
NODE_ENV=development

# CLI (dossier scrape / dossier fetch)
LINKEDIN_EMAIL=you@example.com
LINKEDIN_PASSWORD=secret
PLAYWRIGHT_HEADLESS=true
# Maximum LinkedIn profile visits per day (View budget)
VIEW_BUDGET=25
# Maximum profiles to pull from a single search run
SEARCH_LIMIT=100

# Worker
ANTHROPIC_API_KEY=sk-ant-...
# BullMQ worker concurrency
CONCURRENCY=2
# Directory containing Mode files (system prompt markdowns)
MODE_DIR=./modes

# Dashboard
PORT=3000
SESSION_SECRET=change-me-in-production
